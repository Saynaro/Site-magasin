

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// 1. User's roles
enum Role {
  USER
  ADMIN
}

// 2. Order status
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  name       String   @db.VarChar(50)
  surname    String   @db.VarChar(50)
  avatar     String?  @db.VarChar(512) // Link to profile photo
  adresse    String?  @db.VarChar(255)
  role       Role     @default(USER)
  created_at DateTime @default(now()) @db.Timestamp(0)

  orders     Order[]
  reviews    Review[]
  cartItems  CartItem[] // Users cart

  @@map("users")
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique @db.VarChar(255)
  name            String   @db.VarChar(255)
  description     String   @db.Text
  priceCents      Int
  
  // Связь с категорией
  categoryId      Int      @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id])
  
  image           String   @db.VarChar(512) // Main photo
  images          String[]                  // Photo complement
  
  variants        Json?    // RAM, color etc.
  characteristics Json?   
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  reviews         Review[]
  orderItems      OrderItem[] // Product in payed order
  cartItems       CartItem[]  // Product in cart

  @@index([slug])
  @@map("products")
}

model Category {
  id             Int        @id @default(autoincrement())
  name           String     @unique
  
  // Subcategory logic
  parentId       Int?       @map("parent_id")
  parent         Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subCategories  Category[] @relation("SubCategories")

  products       Product[]

  @@map("categories")
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int         @map("user_id")
  status        OrderStatus @default(PENDING)
  totalAmount   Int         // order's summary
  created_at    DateTime    @default(now()) @db.Timestamp(0)
  deliveryDate  DateTime?   // When arrive

  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[] // Order's contain

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId String  @map("product_id")
  quantity  Int     @default(1)
  price     Int     // Price when it's been shopped
  variant   Json?   // What variant has been buyed

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  productId String  @map("product_id")
  quantity  Int     @default(1)
  variant   Json?   // the color or ram choosed in cart

  user      User    @relation(fields: [userId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Review {
  id            Int        @id @default(autoincrement())
  productId     String     @map("product_id")
  userId        Int        @map("user_id")
  stars         Int        @db.SmallInt // from 1 to 5
  text          String     @db.Text
  created_at    DateTime   @default(now()) @db.Timestamp(0)

  product       Product    @relation(fields: [productId], references: [id])
  user          User       @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  imageUrl    String   @db.VarChar(512)
  link        String?  @db.VarChar(255) // where goes banner onclick
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}